{
  "name": "qt-vsc-extension",
  "displayName": "Qt C++ Tools",
  "description": "Build, run and manage Qt C++ projects in VS Code",
  "version": "2.6.0",
  "publisher": "akhilp19",
  "author": {
    "name": "Akhil Pawar"
  },
  "license": "MIT",
  "icon": "images/qt_tools_logo.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/akhilpawar/Qt-VSC-Extension"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Testing",
    "Other"
  ],
  "keywords": [
    "qt",
    "qt5",
    "qt6",
    "c++",
    "cpp",
    "qmake",
    "cmake",
    "build",
    "qml",
    "qtquick"
  ],
  "activationEvents": [
    "workspaceContains:**/*.pro",
    "workspaceContains:**/CMakeLists.txt",
    "onLanguage:cpp",
    "onLanguage:qml",
    "onLanguage:python",
    "onView:qt-projects"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "qt.buildProject",
        "title": "Qt: Build Project",
        "icon": "$(tools)"
      },
      {
        "command": "qt.cleanProject",
        "title": "Qt: Clean Project",
        "icon": "$(trash)"
      },
      {
        "command": "qt.rebuildProject",
        "title": "Qt: Rebuild Project",
        "icon": "$(refresh)"
      },
      {
        "command": "qt.runProject",
        "title": "Qt: Run Project",
        "icon": "$(run)"
      },
      {
        "command": "qt.configureQt",
        "title": "Qt: Configure Qt Installation Path"
      },
      {
        "command": "qt.selectQtVersion",
        "title": "Qt: Select Qt Version"
      },
      {
        "command": "qt.createQMakeProject",
        "title": "Qt: Create New QMake Project"
      },
      {
        "command": "qt.createCMakeProject",
        "title": "Qt: Create New CMake Project"
      },
      {
        "command": "qt.refreshProjects",
        "title": "Qt: Refresh Projects",
        "icon": "$(refresh)"
      },
      {
        "command": "qt.openInDesigner",
        "title": "Qt: Open in Qt Designer",
        "icon": "$(preview)"
      },
      {
        "command": "qt.validateQrc",
        "title": "Qt: Validate Resource File"
      },
      {
        "command": "qt.runRcc",
        "title": "Qt: Compile Resource File (rcc)"
      },
      {
        "command": "qt.deploy",
        "title": "Qt: Deploy Application",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "qt.configureIntelliSense",
        "title": "Qt: Configure IntelliSense"
      },
      {
        "command": "qt.selectBuildConfig",
        "title": "Qt: Select Build Configuration"
      },
      {
        "command": "qt.importQtCreator",
        "title": "Qt: Import Qt Creator Settings"
      },
      {
        "command": "qt.quickBuild",
        "title": "Qt: Quick Build",
        "icon": "$(zap)"
      },
      {
        "command": "qt.installQt",
        "title": "Qt: Install Qt",
        "icon": "$(cloud-download)"
      },
      {
        "command": "qt.formatQml",
        "title": "Qt: Format QML File",
        "icon": "$(wand)"
      },
      {
        "command": "qt.lintQml",
        "title": "Qt: Lint QML File",
        "icon": "$(check)"
      },
      {
        "command": "qt.previewQml",
        "title": "Qt: Preview QML File",
        "icon": "$(play)"
      },
      {
        "command": "qt.stopQmlPreview",
        "title": "Qt: Stop QML Preview",
        "icon": "$(debug-stop)"
      },
      {
        "command": "qt.rebuildQmlCppIndex",
        "title": "Qt: Rebuild QML-C++ Index",
        "icon": "$(refresh)"
      },
      {
        "command": "qt.generateLaunchJson",
        "title": "Qt: Generate Debug Launch Configuration",
        "icon": "$(debug)"
      },
      {
        "command": "qt.setupPrettyPrinters",
        "title": "Qt: Setup Qt Pretty Printers",
        "icon": "$(symbol-misc)"
      },
      {
        "command": "qt.addSignalSlotBreakpoint",
        "title": "Qt: Add Signal/Slot Breakpoint",
        "icon": "$(debug-breakpoint)"
      },
      {
        "command": "qt.lupdate",
        "title": "Qt: Update Translations (lupdate)",
        "icon": "$(refresh)"
      },
      {
        "command": "qt.lrelease",
        "title": "Qt: Compile Translations (lrelease)",
        "icon": "$(run)"
      },
      {
        "command": "qt.openInLinguist",
        "title": "Qt: Open in Qt Linguist",
        "icon": "$(preview)"
      },
      {
        "command": "qt.refreshTranslations",
        "title": "Qt: Refresh Translations",
        "icon": "$(refresh)"
      },
      {
        "command": "qt.compileUiToPython",
        "title": "Qt: Compile .ui to Python (pyside6-uic)",
        "icon": "$(file-code)"
      },
      {
        "command": "qt.compileRccToPython",
        "title": "Qt: Compile .qrc to Python (pyside6-rcc)",
        "icon": "$(file-code)"
      },
      {
        "command": "qt.openPythonDesigner",
        "title": "Qt: Open Qt Designer (Python)",
        "icon": "$(preview)"
      },
      {
        "command": "qt.generateMoc",
        "title": "Qt: Generate MOC",
        "icon": "$(file-code)"
      },
      {
        "command": "qt.generateUic",
        "title": "Qt: Generate UIC",
        "icon": "$(file-code)"
      },
      {
        "command": "qt.generateRcc",
        "title": "Qt: Generate RCC",
        "icon": "$(file-code)"
      },
      {
        "command": "qt.goToGeneratedCode",
        "title": "Qt: Go to Generated Code",
        "icon": "$(link-external)"
      },
      {
        "command": "qt.peekGeneratedCode",
        "title": "Qt: Peek Generated Code",
        "icon": "$(open-preview)"
      },
      {
        "command": "qt.generatePch",
        "title": "Qt: Generate Precompiled Header",
        "icon": "$(rocket)"
      },
      {
        "command": "qt.generateCustomMakefile",
        "title": "Qt: Generate Custom Build Makefile",
        "icon": "$(file-code)"
      },
      {
        "command": "qt.integratePch",
        "title": "Qt: Integrate Precompiled Header into Build",
        "icon": "$(gear)"
      },
      {
        "command": "qt.injectBuildScripts",
        "title": "Qt: Inject MOC/UIC/RCC into Build Script",
        "icon": "$(plug)"
      },
      {
        "command": "qt.configurePchCompiler",
        "title": "Qt: Configure PCH Compiler Flags",
        "icon": "$(symbol-operator)"
      },
      {
        "command": "qt.setupCiCd",
        "title": "Qt: Setup CI/CD Pipeline",
        "icon": "$(server-process)"
      },
      {
        "command": "qt.generateInstallerConfig",
        "title": "Qt: Generate Installer Framework Config",
        "icon": "$(file-zip)"
      },
      {
        "command": "qt.buildInstaller",
        "title": "Qt: Build Installer",
        "icon": "$(package)"
      },
      {
        "command": "qt.showBuildAnalytics",
        "title": "Qt: Show Build Analytics",
        "icon": "$(graph)"
      },
      {
        "command": "qt.configureCcache",
        "title": "Qt: Configure ccache/sccache",
        "icon": "$(database)"
      },
      {
        "command": "qt.showCcacheStats",
        "title": "Qt: Show ccache Stats",
        "icon": "$(output)"
      },
      {
        "command": "qt.configureTelemetry",
        "title": "Qt: Configure Telemetry",
        "icon": "$(radio-tower)"
      },
      {
        "command": "qt.exportTelemetry",
        "title": "Qt: Export Telemetry Data",
        "icon": "$(export)"
      },
      {
        "command": "qt.launchQmlProfiler",
        "title": "Qt: Launch QML Profiler",
        "icon": "$(debug-alt)"
      },
      {
        "command": "qt.launchCpuProfiler",
        "title": "Qt: Launch CPU Profiler",
        "icon": "$(pulse)"
      },
      {
        "command": "qt.launchMemoryProfiler",
        "title": "Qt: Launch Memory Leak Detector",
        "icon": "$(bug)"
      },
      {
        "command": "qt.detectSlowTargets",
        "title": "Qt: Detect Slow Compilation Targets",
        "icon": "$(clock)"
      },
      {
        "command": "qt.selectCMakePreset",
        "title": "Qt: Select CMake Preset",
        "icon": "$(list-selection)"
      },
      {
        "command": "qt.clearCMakePreset",
        "title": "Qt: Clear CMake Preset",
        "icon": "$(clear-all)"
      },
      {
        "command": "qt.runClazy",
        "title": "Qt: Run clazy / clang-tidy on Workspace",
        "icon": "$(search)"
      },
      {
        "command": "qt.runClazyOnFile",
        "title": "Qt: Run clazy / clang-tidy on Current File",
        "icon": "$(search)"
      },
      {
        "command": "qt.openQtDocumentation",
        "title": "Qt: Open Qt Documentation",
        "icon": "$(book)"
      },
      {
        "command": "qt.buildAndroidApk",
        "title": "Qt: Build Android APK",
        "icon": "$(device-mobile)"
      },
      {
        "command": "qt.configureAndroidSdk",
        "title": "Qt: Configure Android SDK",
        "icon": "$(gear)"
      },
      {
        "command": "qt.installAndroidApk",
        "title": "Qt: Install Android APK",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "qt.selectBuildKit",
        "title": "Qt: Select Build Kit",
        "icon": "$(list-selection)"
      },
      {
        "command": "qt.configureBuildKit",
        "title": "Qt: Configure Build Kit",
        "icon": "$(gear)"
      },
      {
        "command": "qt.detectBuildKits",
        "title": "Qt: Detect Build Kits",
        "icon": "$(search)"
      },
      {
        "command": "qt.buildAndroidAab",
        "title": "Qt: Build Android AAB",
        "icon": "$(package)"
      },
      {
        "command": "qt.validateAndroidManifest",
        "title": "Qt: Validate Android Manifest",
        "icon": "$(check)"
      },
      {
        "command": "qt.buildIOSApp",
        "title": "Qt: Build iOS App",
        "icon": "$(device-mobile)"
      },
      {
        "command": "qt.selectIOSSimulator",
        "title": "Qt: Select iOS Simulator",
        "icon": "$(list-selection)"
      },
      {
        "command": "qt.runIOSOnSimulator",
        "title": "Qt: Run iOS App on Simulator",
        "icon": "$(run)"
      },
      {
        "command": "qt.buildWebAssembly",
        "title": "Qt: Build for WebAssembly",
        "icon": "$(globe)"
      },
      {
        "command": "qt.configureEmscripten",
        "title": "Qt: Configure Emscripten SDK",
        "icon": "$(gear)"
      },
      {
        "command": "qt.serveWebAssembly",
        "title": "Qt: Serve WebAssembly Preview",
        "icon": "$(preview)"
      },
      {
        "command": "qt.configureKitToolchain",
        "title": "Qt: Configure Kit Toolchain",
        "icon": "$(gear)"
      },
      {
        "command": "qt.exportBuildKits",
        "title": "Qt: Export Build Kits",
        "icon": "$(cloud-download)"
      },
      {
        "command": "qt.importBuildKits",
        "title": "Qt: Import Build Kits",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "qt.runHealthCheck",
        "title": "Qt: Run Health Check",
        "icon": "$(pass)"
      },
      {
        "command": "qt.archiveIOSApp",
        "title": "Qt: Archive iOS App",
        "icon": "$(archive)"
      },
      {
        "command": "qt.exportIOSIpa",
        "title": "Qt: Export iOS IPA",
        "icon": "$(package)"
      },
      {
        "command": "qt.validateBuildKit",
        "title": "Qt: Validate Build Kit",
        "icon": "$(check)"
      },
      {
        "command": "qt.uploadIOSTestFlight",
        "title": "Qt: Upload iOS IPA to TestFlight",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "qt.takeSimulatorScreenshot",
        "title": "Qt: Take iOS Simulator Screenshot",
        "icon": "$(device-camera)"
      },
      {
        "command": "qt.recordSimulatorVideo",
        "title": "Qt: Record iOS Simulator Video",
        "icon": "$(record)"
      },
      {
        "command": "qt.stopSimulatorRecording",
        "title": "Qt: Stop iOS Simulator Recording",
        "icon": "$(debug-stop)"
      },
      {
        "command": "qt.buildAndroidApks",
        "title": "Qt: Build Android APKS from AAB",
        "icon": "$(package)"
      },
      {
        "command": "qt.installAndroidApks",
        "title": "Qt: Install Android APKS",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "qt.startAndroidLogcat",
        "title": "Qt: Start Android Logcat",
        "icon": "$(output)"
      },
      {
        "command": "qt.stopAndroidLogcat",
        "title": "Qt: Stop Android Logcat",
        "icon": "$(debug-stop)"
      },
      {
        "command": "qt.deployRemote",
        "title": "Qt: Deploy to Remote Device",
        "icon": "$(server-process)"
      },
      {
        "command": "qt.configureRemoteTarget",
        "title": "Qt: Configure Remote Target",
        "icon": "$(gear)"
      },
      {
        "command": "qt.generateRemoteDebugConfig",
        "title": "Qt: Generate Remote Debug Config",
        "icon": "$(debug)"
      }
    ],
    "taskDefinitions": [
      {
        "type": "qt",
        "required": [
          "task"
        ],
        "properties": {
          "task": {
            "type": "string",
            "description": "Qt task to execute",
            "enum": [
              "build",
              "clean",
              "rebuild",
              "run"
            ]
          },
          "file": {
            "type": "string",
            "description": "Qt project file (.pro or CMakeLists.txt)"
          },
          "buildType": {
            "type": "string",
            "description": "Build configuration",
            "enum": [
              "debug",
              "release"
            ]
          },
          "quickBuild": {
            "type": "boolean",
            "default": false,
            "description": "Skip qmake/cmake reconfiguration if build directory exists"
          }
        }
      }
    ],
    "configuration": {
      "title": "Qt C++ Tools",
      "properties": {
        "qt.qmakePath": {
          "type": "string",
          "default": "",
          "description": "Full path to qmake executable. Leave empty for auto-detection."
        },
        "qt.qtInstallPath": {
          "type": "string",
          "default": "",
          "description": "Qt installation directory (e.g., C:\\Qt\\6.5.0\\msvc2019_64). Leave empty for auto-detection."
        },
        "qt.autoDetect": {
          "type": "string",
          "enum": [
            "on",
            "off"
          ],
          "default": "on",
          "description": "Automatically detect Qt projects in workspace"
        },
        "qt.buildDirectory": {
          "type": "string",
          "default": "${workspaceFolder}/build",
          "description": "Directory for build output"
        },
        "qt.defaultBuildType": {
          "type": "string",
          "enum": [
            "debug",
            "release"
          ],
          "default": "debug",
          "description": "Default build configuration"
        },
        "qt.makeCommand": {
          "type": "string",
          "enum": [
            "auto",
            "nmake",
            "mingw32-make",
            "jom",
            "make"
          ],
          "default": "auto",
          "description": "Make command to use for building. 'auto' will detect from Qt installation."
        },
        "qt.additionalQMakeArguments": {
          "type": "string",
          "default": "",
          "description": "Additional arguments to pass to qmake"
        },
        "qt.additionalCMakeArguments": {
          "type": "string",
          "default": "",
          "description": "Additional arguments to pass to cmake"
        },
        "qt.showBuildOutput": {
          "type": "boolean",
          "default": true,
          "description": "Show build output in terminal"
        },
        "qt.clearOutputBeforeBuild": {
          "type": "boolean",
          "default": true,
          "description": "Clear output terminal before building"
        },
        "qt.deployDirectory": {
          "type": "string",
          "default": "${workspaceFolder}/deploy",
          "description": "Directory for deployment output (windeployqt)"
        },
        "qt.additionalWinDeployQtArguments": {
          "type": "string",
          "default": "",
          "description": "Additional arguments to pass to windeployqt"
        },
        "qt.preBuildCommand": {
          "type": "string",
          "default": "",
          "description": "Command to run before build (e.g., code generation)"
        },
        "qt.postBuildCommand": {
          "type": "string",
          "default": "",
          "description": "Command to run after build (e.g., copy assets)"
        },
        "qt.projectBuildConfigurations": {
          "type": "object",
          "default": {},
          "description": "Per-project build configurations (debug/release). Managed by the extension."
        },
        "qt.parallelJobs": {
          "type": "number",
          "default": 0,
          "description": "Number of parallel jobs for compilation. 0 = auto-detect based on CPU cores."
        },
        "qt.packageManagerAutoDetect": {
          "type": "boolean",
          "default": true,
          "description": "Automatically detect Qt installations from package managers (Homebrew, APT, Pacman, vcpkg, Conan, aqtinstall)."
        },
        "qt.preferredPackageManager": {
          "type": "string",
          "enum": [
            "auto",
            "official",
            "homebrew",
            "apt",
            "pacman",
            "vcpkg",
            "conan",
            "aqtinstall"
          ],
          "default": "auto",
          "description": "Preferred source for Qt installations. 'auto' uses the first found. 'official' prefers Qt installer over package managers."
        },
        "qt.showQtSource": {
          "type": "boolean",
          "default": true,
          "description": "Show package manager source badge (e.g., [Homebrew]) next to Qt versions in the picker."
        },
        "qt.qmlFormatOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Automatically format QML files on save using qmlformat."
        },
        "qt.qmlLintOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Automatically lint QML files on save using qmllint and show diagnostics in the Problems panel."
        },
        "qt.qmlPreviewImportPath": {
          "type": "string",
          "default": "",
          "description": "Additional QML2_IMPORT_PATH for QML preview (qmlscene)."
        },
        "qt.qmlPreviewArgs": {
          "type": "string",
          "default": "",
          "description": "Additional command-line arguments to pass to qmlscene when previewing QML files."
        },
        "qt.qmlPreviewHotReload": {
          "type": "boolean",
          "default": false,
          "description": "Automatically restart QML preview (qmlscene) when the QML file is saved."
        },
        "qt.qmlCppBridgeEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable QML-C++ bridge features (Go to Definition, autocomplete, Find References)."
        },
        "qt.qmlCppIndexExclude": {
          "type": "array",
          "default": [
            "**/build/**",
            "**/out/**",
            "**/.git/**",
            "**/node_modules/**"
          ],
          "description": "Glob patterns to exclude from QML-C++ bridge indexing.",
          "items": {
            "type": "string"
          }
        },
        "qt.debuggerType": {
          "type": "string",
          "enum": [
            "auto",
            "cppvsdbg",
            "gdb",
            "lldb"
          ],
          "default": "auto",
          "description": "Override auto-detected debugger type. 'auto' detects from compiler and platform."
        },
        "qt.debugAdditionalArgs": {
          "type": "string",
          "default": "",
          "description": "Additional arguments passed to the debug target when launching."
        },
        "qt.qmlDebugPort": {
          "type": "number",
          "default": 3768,
          "description": "Port for QML JS debugger."
        },
        "qt.testAutoDiscover": {
          "type": "boolean",
          "default": true,
          "description": "Automatically discover Qt Test classes in the workspace and populate the Test Explorer."
        },
        "qt.lupdateArgs": {
          "type": "string",
          "default": "",
          "description": "Additional arguments to pass to lupdate when updating translations."
        },
        "qt.lreleaseArgs": {
          "type": "string",
          "default": "",
          "description": "Additional arguments to pass to lrelease when compiling translations."
        },
        "qt.pythonQtBinding": {
          "type": "string",
          "enum": [
            "auto",
            "PySide6",
            "PyQt6",
            "PySide2",
            "PyQt5"
          ],
          "default": "auto",
          "description": "Preferred Python Qt binding. 'auto' detects from imports in workspace Python files."
        },
        "qt.autoMoc": {
          "type": "boolean",
          "default": false,
          "description": "Automatically run moc on C++ header files containing Q_OBJECT when saved."
        },
        "qt.autoUic": {
          "type": "boolean",
          "default": false,
          "description": "Automatically run uic on .ui files when saved."
        },
        "qt.autoRcc": {
          "type": "boolean",
          "default": false,
          "description": "Automatically run rcc on .qrc files when saved."
        },
        "qt.generatedCodeDirectory": {
          "type": "string",
          "default": "",
          "description": "Output directory for auto-generated code (moc_*.cpp, ui_*.h, qrc_*.cpp). Empty = same directory as input file. Supports ${workspaceFolder} variable."
        },
        "qt.useCcache": {
          "type": "boolean",
          "default": false,
          "description": "Use ccache or sccache for faster Qt builds. Detects and configures automatically when enabled."
        },
        "qt.ccachePath": {
          "type": "string",
          "default": "",
          "description": "Custom path to ccache or sccache executable. Leave empty for auto-detection."
        },
        "qt.cmakePresets": {
          "type": "object",
          "default": {},
          "description": "Per-project CMake preset selections. Managed by the extension."
        },
        "qt.clazyEnable": {
          "type": "boolean",
          "default": false,
          "description": "Enable clazy / clang-tidy static analysis for Qt C++ code."
        },
        "qt.clazyChecks": {
          "type": "string",
          "default": "",
          "description": "Comma-separated list of clazy check names (e.g., 'level1,connect-by-name'). Leave empty for default checks."
        },
        "qt.clazyOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Run clazy / clang-tidy automatically when C++ files are saved."
        },
        "qt.androidSdkPath": {
          "type": "string",
          "default": "",
          "description": "Path to Android SDK directory."
        },
        "qt.androidNdkPath": {
          "type": "string",
          "default": "",
          "description": "Path to Android NDK directory."
        },
        "qt.androidPlatform": {
          "type": "string",
          "default": "android-34",
          "description": "Android platform level for APK builds (e.g., android-34)."
        },
        "qt.buildKits": {
          "type": "array",
          "default": [],
          "description": "Array of build kit definitions. Managed by the extension."
        },
        "qt.activeKit": {
          "type": "object",
          "default": {},
          "description": "Per-project active build kit map. Managed by the extension."
        },
        "qt.iosSelectedSimulator": {
          "type": "string",
          "default": "",
          "description": "UDID of the selected iOS simulator for deployment."
        },
        "qt.iosBuildForDevice": {
          "type": "boolean",
          "default": false,
          "description": "Build iOS app for physical device instead of simulator."
        },
        "qt.emscriptenPath": {
          "type": "string",
          "default": "",
          "description": "Path to the Emscripten SDK root directory."
        },
        "qt.wasmBuildDirectory": {
          "type": "string",
          "default": "${workspaceFolder}/build-wasm",
          "description": "Build directory for WebAssembly builds."
        },
        "qt.wasmServePort": {
          "type": "number",
          "default": 8080,
          "description": "Port for the WebAssembly preview HTTP server."
        },
        "qt.defaultKit": {
          "type": "string",
          "default": "",
          "description": "Default build kit name for the workspace. Used when no per-project kit is selected."
        },
        "qt.iosAppleId": {
          "type": "string",
          "default": "",
          "description": "Apple ID email for TestFlight / App Store upload via altool."
        },
        "qt.iosAppSpecificPassword": {
          "type": "string",
          "default": "",
          "description": "App-specific password for TestFlight / App Store upload."
        },
        "qt.iosApiKeyPath": {
          "type": "string",
          "default": "",
          "description": "Path to App Store Connect API private key (.p8)."
        },
        "qt.iosApiIssuerId": {
          "type": "string",
          "default": "",
          "description": "App Store Connect API issuer ID."
        },
        "qt.iosApiKeyId": {
          "type": "string",
          "default": "",
          "description": "App Store Connect API key ID."
        },
        "qt.iosSimulatorMediaDir": {
          "type": "string",
          "default": "${workspaceFolder}/ios-media",
          "description": "Directory for iOS simulator screenshots and recordings."
        },
        "qt.androidBundletoolPath": {
          "type": "string",
          "default": "",
          "description": "Path to bundletool.jar for AAB testing."
        },
        "qt.androidKeystorePath": {
          "type": "string",
          "default": "",
          "description": "Path to keystore for signing APKS generated from AAB."
        },
        "qt.androidKeystorePassword": {
          "type": "string",
          "default": "",
          "description": "Password for the Android keystore."
        },
        "qt.androidKeyAlias": {
          "type": "string",
          "default": "",
          "description": "Key alias for the Android keystore."
        },
        "qt.androidPreferGradleWrapper": {
          "type": "boolean",
          "default": true,
          "description": "Use the project's Gradle wrapper (gradlew) for Android builds when available."
        },
        "qt.remoteHost": {
          "type": "string",
          "default": "",
          "description": "Remote device hostname or IP for deployment and debugging."
        },
        "qt.remoteUser": {
          "type": "string",
          "default": "",
          "description": "Remote user name for deployment and debugging."
        },
        "qt.remotePath": {
          "type": "string",
          "default": "",
          "description": "Remote directory to deploy the built application."
        },
        "qt.remoteDeployMode": {
          "type": "string",
          "enum": [
            "scp",
            "rsync"
          ],
          "default": "scp",
          "description": "Remote deployment mode."
        },
        "qt.remoteDebugPort": {
          "type": "number",
          "default": 2345,
          "description": "GDB server port for remote debugging."
        },
        "qt.cppLspEnable": {
          "type": "boolean",
          "default": true,
          "description": "Enable the Qt C++ Language Server for signal/slot aware code intelligence."
        },
        "qt.cppLspServerPath": {
          "type": "string",
          "default": "",
          "description": "Custom path to the compiled Qt C++ LSP server script (out/qtCppLanguageServer.js). Leave empty for auto-detection."
        },
        "qt.cppLspDiagnosticsEnable": {
          "type": "boolean",
          "default": true,
          "description": "Enable Qt-specific diagnostics from the Qt C++ Language Server (missing Q_OBJECT, old-style connect, etc.)."
        },
        "qt.telemetryEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Opt in to send anonymous usage and error telemetry to help improve Qt C++ Tools."
        },
        "qt.telemetryEndpoint": {
          "type": "string",
          "default": "",
          "description": "Optional HTTPS endpoint to flush anonymous telemetry events. Leave empty to keep events local only."
        },
        "qt.perFileTimingEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Collect and display per-file compilation timing from Qt build output."
        }
      }
    },
    "problemMatchers": [
      {
        "name": "qt-qmake",
        "owner": "qt",
        "fileLocation": [
          "relative",
          "${workspaceFolder}"
        ],
        "pattern": {
          "regexp": "^(.*):(\\d+):\\s+(warning|error):\\s+(.*)$",
          "file": 1,
          "line": 2,
          "severity": 3,
          "message": 4
        }
      }
    ],
