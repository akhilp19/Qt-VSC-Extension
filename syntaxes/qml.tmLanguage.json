{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "QML",
  "scopeName": "source.qml",
  "fileTypes": [".qml", ".qmltypes"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#imports" },
    { "include": "#pragmas" },
    { "include": "#component-declaration" },
    { "include": "#property-declaration" },
    { "include": "#signal-declaration" },
    { "include": "#function-declaration" },
    { "include": "#enum-declaration" },
    { "include": "#signal-handler" },
    { "include": "#type-usage" },
    { "include": "#keywords" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#js-expressions" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.qml",
          "begin": "/\\*",
          "end": "\\*/"
        },
        {
          "name": "comment.line.double-slash.qml",
          "begin": "//",
          "end": "$"
        }
      ]
    },
    "imports": {
      "patterns": [
        {
          "name": "meta.import.qml",
          "match": "^\\s*(import)\\s+([A-Za-z][A-Za-z0-9.]*)\\s+([0-9]+\\.[0-9]+)(?:\\s+(as)\\s+([A-Za-z][A-Za-z0-9]*))?",
          "captures": {
            "1": { "name": "keyword.control.import.qml" },
            "2": { "name": "entity.name.type.module.qml" },
            "3": { "name": "constant.numeric.qml" },
            "4": { "name": "keyword.control.import.qml" },
            "5": { "name": "entity.name.type.namespace.qml" }
          }
        },
        {
          "name": "meta.import.qml",
          "match": "^\\s*(import)\\s+(\"[^\"]+\")(?:\\s+([0-9]+\\.[0-9]+))?(?:\\s+(as)\\s+([A-Za-z][A-Za-z0-9]*))?",
          "captures": {
            "1": { "name": "keyword.control.import.qml" },
            "2": { "name": "string.quoted.double.qml" },
            "3": { "name": "constant.numeric.qml" },
            "4": { "name": "keyword.control.import.qml" },
            "5": { "name": "entity.name.type.namespace.qml" }
          }
        }
      ]
    },
    "pragmas": {
      "patterns": [
        {
          "name": "meta.pragma.qml",
          "match": "^\\s*(pragma)\\s+([A-Za-z][A-Za-z0-9]*)(?:\\s+(.*))?",
          "captures": {
            "1": { "name": "keyword.other.pragma.qml" },
            "2": { "name": "support.constant.pragma.qml" }
          }
        }
      ]
    },
    "component-declaration": {
      "patterns": [
        {
          "name": "meta.component.qml",
          "begin": "^\\s*(component)\\s+([A-Za-z][A-Za-z0-9_]*)\\s*:",
          "beginCaptures": {
            "1": { "name": "keyword.other.component.qml" },
            "2": { "name": "entity.name.type.component.qml" }
          },
          "end": "(?=^\\s*(?:component|import|pragma|[A-Z]))",
          "patterns": [
            { "include": "$self" }
          ]
        }
      ]
    },
    "property-declaration": {
      "patterns": [
        {
          "name": "meta.property.qml",
          "match": "\\b(property)\\s+(?:(readonly|required|default)\\s+)?(?:([A-Z][A-Za-z0-9_]*)|([a-z][a-z0-9_]*))\\s+([a-z][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.other.property.qml" },
            "2": { "name": "storage.modifier.qml" },
            "3": { "name": "entity.name.type.qml" },
            "4": { "name": "storage.type.qml" },
            "5": { "name": "variable.other.property.qml" }
          }
        }
      ]
    },
    "signal-declaration": {
      "patterns": [
        {
          "name": "meta.signal.qml",
          "match": "\\b(signal)\\s+([a-z][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.other.signal.qml" },
            "2": { "name": "entity.name.function.signal.qml" }
          }
        }
      ]
    },
    "function-declaration": {
      "patterns": [
        {
          "name": "meta.function.qml",
          "match": "\\b(function)\\s+([a-z][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.control.function.qml" },
            "2": { "name": "entity.name.function.qml" }
          }
        }
      ]
    },
    "enum-declaration": {
      "patterns": [
        {
          "name": "meta.enum.qml",
          "begin": "\\b(enum)\\s*\\{",
          "beginCaptures": {
            "1": { "name": "keyword.other.enum.qml" }
          },
          "end": "\\}",
          "patterns": [
            {
              "name": "constant.other.enum.qml",
              "match": "[A-Za-z][A-Za-z0-9_]*"
            }
          ]
        }
      ]
    },
    "signal-handler": {
      "patterns": [
        {
          "name": "meta.signal-handler.qml",
          "match": "\\b(on[A-Z][A-Za-z0-9_]*)\\s*:",
          "captures": {
            "1": { "name": "support.function.signal-handler.qml" }
          }
        }
      ]
    },
    "type-usage": {
      "patterns": [
        {
          "name": "meta.type.qml",
          "begin": "^\\s*([A-Z][A-Za-z0-9_\\.]*)(?:\\s+([a-z][A-Za-z0-9_]*))?\\s*\\{",
          "beginCaptures": {
            "1": { "name": "entity.name.type.qml" },
            "2": { "name": "entity.name.tag.id.qml" }
          },
          "end": "\\}",
          "patterns": [
            { "include": "$self" }
          ]
        },
        {
          "name": "meta.type.qml",
          "match": "^\\s*([A-Z][A-Za-z0-9_\\.]*)(?:\\s+([a-z][A-Za-z0-9_]*))?(?=\\s*:")",
          "captures": {
            "1": { "name": "entity.name.type.qml" },
            "2": { "name": "entity.name.tag.id.qml" }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.qml",
          "match": "\\b(?:if|else|for|while|do|switch|case|default|break|continue|return|try|catch|finally|throw)\\b"
        },
        {
          "name": "keyword.other.qml",
          "match": "\\b(?:as|on|alias|readonly|required|default|list|var|let|const|delete|typeof|instanceof|in|of|new|this|true|false|null|undefined|void|with|debugger)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.qml",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.qml",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.qml",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.qml",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.template.qml",
          "begin": "`",
          "end": "`",
          "patterns": [
            {
              "name": "constant.character.escape.qml",
              "match": "\\\\."
            },
            {
              "name": "constant.other.placeholder.qml",
              "match": "\\$\\{[^}]*\\}"
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.qml",
          "match": "\\b(?:0[xX][0-9a-fA-F]+|(?:\\d+\\.\\d*|\\.\\d+|\\d+)(?:[eE][+-]?\\d+)?)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.qml",
          "match": "(===|!==|==|!=|<=|>=|<<|>>|>>>|&&|\\|\\||\\+\\+|--|\\+|-|\\*|/|%|&|\\||\\^|~|!|<|>|=|\\?|:)"
        }
      ]
    },
    "js-expressions": {
      "patterns": [
        {
          "name": "meta.function-call.qml",
          "match": "([a-z][A-Za-z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.qml" }
          }
        },
        {
          "name": "support.class.qml",
          "match": "\\b(?:console|Math|Date|JSON|Array|Object|String|Number|Boolean|RegExp|Error|Qt|qsTr|qsTranslate|QT_TR_NOOP|QT_TRANSLATE_NOOP)\\b"
        }
      ]
    }
  }
}
