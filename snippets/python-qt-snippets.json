    "prefix": "pyside-app",
    "body": [
      "import sys",
      "from PySide6.QtWidgets import QApplication, QMainWindow",
      "",
      "",
      "class MainWindow(QMainWindow):",
      "    def __init__(self):",
      "        super().__init__()",
      "        self.setWindowTitle(\"${1:My App}\")",
      "        self.setGeometry(100, 100, 800, 600)",
      "        ${2:# TODO: Add widgets}",
      "",
      "",
      "if __name__ == \"__main__\":",
      "    app = QApplication(sys.argv)",
      "    window = MainWindow()",
      "    window.show()",
      "    sys.exit(app.exec())",
      ""
    ],
    "description": "PySide6 QApplication + MainWindow"
  },
